apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: eightbitsaxlounge-state
  labels:
    app: eightbitsaxlounge
    component: state
spec:
  serviceName: eightbitsaxlounge-state-headless
  replicas: 1
  selector:
    matchLabels:
      app: eightbitsaxlounge
      component: state
  template:
    metadata:
      labels:
        app: eightbitsaxlounge
        component: state
    spec:
      containers:
        - name: nats
          image: {{ state_image }}
          imagePullPolicy: Always
          args: ["-c", "/etc/nats/nats.conf"]
          ports:
            - name: client
              containerPort: 4222
            - name: monitor
              containerPort: 8222
            - name: cluster
              containerPort: 6222
          lifecycle:
            postStart:
              exec:
                command:
                  - /bin/sh
                  - -c
                  - "sleep 2 && /usr/local/bin/jetstream-bootstrap.sh"
          env:
            - name: NATS_URL
              value: "nats://127.0.0.1:4222"
            - name: SYSTEM_PASS
              valueFrom:
                secretKeyRef:
                  name: state-nats-creds
                  key: system_pass
            - name: OVERLAY_PASS
              valueFrom:
                secretKeyRef:
                  name: state-nats-creds
                  key: overlay_pass
            - name: UI_PASS
              valueFrom:
                secretKeyRef:
                  name: state-nats-creds
                  key: ui_pass
            - name: MIDI_PASS
              valueFrom:
                secretKeyRef:
                  name: state-nats-creds
                  key: midi_pass
            - name: DATA_PASS
              valueFrom:
                secretKeyRef:
                  name: state-nats-creds
                  key: data_pass
          volumeMounts:
            - name: data
              mountPath: /data
          resources:
            requests:
              cpu: "50m"
              memory: "128Mi"
            limits:
              cpu: "500m"
              memory: "512Mi"
          livenessProbe:
            tcpSocket:
              port: 4222
            initialDelaySeconds: 10
            periodSeconds: 10
            failureThreshold: 3
          readinessProbe:
            tcpSocket:
              port: 4222
            initialDelaySeconds: 5
            periodSeconds: 5
            failureThreshold: 3
  volumeClaimTemplates:
    - metadata:
        name: data
      spec:
        storageClassName: longhorn
        accessModes: [ "ReadWriteOnce" ]
        resources:
          requests:
            storage: 1Gi
