port: 4222
http: 8222
server_name: nats

authorization {
  users = [
    {
      user: "system"
      password: "$SYSTEM_PASS"
      permissions: {
        publish: [">"]
        subscribe: [">"]
      }
    }
    {
      user: "overlay"
      password: "$OVERLAY_PASS"
      permissions: {
        publish: ["overlay.>"]
        subscribe: [
            "overlay.>"
          ]
      }
    }
    {
      user: "chat"
      password: "$CHAT_PASS"
      permissions: {
        publish: [
            "chat.>",
            "overlay.engine",
            "overlay.delay",
            "overlay.time",
            "overlay.dial1",
            "overlay.dial2",
            "overlay.player"
          ]
        subscribe: []
      }
    }
    {
      user: "midi"
      password: "$MIDI_PASS"
      permissions: {
        publish: ["midi.>",
            "overlay.engine",
            "overlay.predelay",
            "overlay.time",
            "overlay.control1",
            "overlay.control2"
          ]
        subscribe: []
      }
    }
    {
      user: "data"
      password: "$DATA_PASS"
      permissions: {
        publish: ["data.>"]
        subscribe: []
      }
    }
  ]
}

jetstream {
  store_dir: "/data/jetstream"
  max_mem_store: 64MB
  max_file_store: 200MB
}

